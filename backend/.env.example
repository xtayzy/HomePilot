# HomePilot Backend — пример переменных окружения
# Скопируйте в .env и заполните

# Окружение: development | staging | production
APP_ENV=development
DEBUG=true
# Порт сервера (по умолчанию 8001)
PORT=8001

# JWT
SECRET_KEY=change-me-in-production-min-32-characters-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL (async для приложения)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/homepilot
# Синхронный URL для Alembic
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/homepilot

# Redis (опционально)
# REDIS_URL=redis://localhost:6379/0

# CORS — через запятую или JSON-массив (порт фронта по умолчанию 3003)
CORS_ORIGINS=http://localhost:3003,http://127.0.0.1:3003

# URL фронтенда для ссылок в письмах (подтверждение email и т.п.)
# FRONTEND_BASE_URL=http://localhost:3003

# Файлы (локально)
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Платежи: mock (код в логе бэкенда) или stripe (Stripe Checkout)
PAYMENT_PROVIDER=mock
# PAYMENT_API_KEY=
# PAYMENT_WEBHOOK_SECRET=

# Stripe (если PAYMENT_PROVIDER=stripe)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# FRONTEND_BASE_URL=https://ваш-домен.tld  — для success/cancel URL в Checkout

# Google Sign-In (тот же Client ID, что VITE_GOOGLE_CLIENT_ID на фронте)
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Сид: логины админ-панели (см. также scripts/create_admin.py)
# SEED_ADMIN_EMAIL=admin@homepilot.kz
# SEED_ADMIN_PASSWORD=минимум8символов
# SEED_SUPPORT_EMAIL=support@homepilot.kz
# SEED_SUPPORT_PASSWORD=минимум8символов

# Email (опционально)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@homepilot.kz

# Локаль по умолчанию
LOCALE_DEFAULT=ru
